{
  "name": "vue-rex-monorepo",
  "private": true,
  "type": "module",
  "description": "Vue Rex monorepo",
  "scripts": {
    "build": "pnpm -C packages/vue-rex build",
    "build:watch": "pnpm -C packages/vue-rex build:watch",
    "test": "pnpm -C packages/vue-rex test",
    "test:ui": "pnpm -C packages/vue-rex test:ui",
    "doc": "pnpm -C docs dev",
    "doc:build": "pnpm -C docs build",
    "doc:preview": "pnpm -C docs preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "type-check": "pnpm -C packages/vue-rex type-check",
    "publish": "pnpm -C packages/vue-rex publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "bumpp": "^10.4.1",
    "eslint": "^9.39.4",
    "lint-staged": "^15.5.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
